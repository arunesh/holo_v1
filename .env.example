# Holodeck configuration. Copy to .env and fill in.

# Required for the AI tutor + pod generation (already set in this environment).
ANTHROPIC_API_KEY=

# Optional. If set, voice uses ElevenLabs; if empty, the browser Web Speech API is used.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Optional model overrides.
HOLODECK_CLAUDE_MODEL=claude-opus-4-8
HOLODECK_GENERATOR_MODEL=claude-opus-4-8
HOLODECK_GPT2_MODEL=gpt2
